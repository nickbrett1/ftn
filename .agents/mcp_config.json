{
  "mcpServers": {
    "svelte": {
      "serverUrl": "https://mcp.svelte.dev/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url",
        "http://127.0.0.1:9222"
      ]
    },
    "circleci": {
      "command": "doppler",
      "args": [
        "run",
        "--project",
        "webapp",
        "--config",
        "dev",
        "--",
        "npx",
        "-y",
        "@circleci/mcp-server-circleci"
      ]
    },
    "sonarqube": {
      "command": "doppler",
      "args": [
        "run",
        "--project",
        "webapp",
        "--config",
        "dev",
        "--",
        "npx",
        "-y",
        "sonarqube-mcp-server"
      ]
    },
    "nanobanana": {
      "command": "node",
      "args": [
        "/home/node/nanobanana-mcp/mcp-server/dist/index.js"
      ],
      "env": {
        "NANOBANANA_GEMINI_API_KEY": "$NANOBANANA_GEMINI_API_KEY"
      }
    },
    "fintechnick": {
      "command": "doppler",
      "args": [
        "run",
        "--project",
        "webapp",
        "--config",
        "dev",
        "--",
        "sh",
        "-c",
        "npx -y mcp-remote https://www.fintechnick.com/api/mcp --header \"Authorization: Bearer $FINTECHNICK_MCP\""
      ]
    },
    "github": {
      "command": "doppler",
      "args": [
        "run",
        "--project",
        "webapp",
        "--config",
        "dev",
        "--",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "doppler": {
      "command": "sh",
      "args": [
        "-c",
        "DOPPLER_TOKEN=$(doppler configure get token --plain) npx -y @dopplerhq/mcp-server"
      ]
    }
  }
}
