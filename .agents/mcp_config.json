{
  "mcpServers": {
    "svelte": {
      "serverUrl": "https://mcp.svelte.dev/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url",
        "http://127.0.0.1:9222"
      ]
    },
    "circleci": {
      "command": "npx",
      "args": [
        "-y",
        "@circleci/mcp-server-circleci"
      ],
      "env": {
        "CIRCLECI_TOKEN": "$CIRCLECI_TOKEN",
        "CIRCLE_API_TOKEN": "$CIRCLE_API_TOKEN"
      }
    },
    "sonarqube": {
      "command": "npx",
      "args": [
        "-y",
        "sonarqube-mcp-server"
      ],
      "env": {
        "SONARQUBE_TOKEN": "$SONARQUBE_TOKEN",
        "SONARQUBE_ORG": "$SONARQUBE_ORG",
        "SONARQUBE_URL": "https://sonarcloud.io",
        "SONARQUBE_IDE_PORT": "$SONARQUBE_IDE_PORT"
      }
    },
    "nanobanana": {
      "command": "node",
      "args": [
        "/home/node/nanobanana-mcp/mcp-server/dist/index.js"
      ],
      "env": {
        "NANOBANANA_GEMINI_API_KEY": "$NANOBANANA_GEMINI_API_KEY"
      }
    }
  }
}
