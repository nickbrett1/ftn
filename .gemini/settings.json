{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url",
        "http://127.0.0.1:9222"
      ]
    },
    "circleci": {
      "command": "npx",
      "args": ["-y", "@circleci/mcp-server-circleci"]
    },
    "sonarqube": {
      "command": "/usr/bin/docker",
      "args": [
        "run",
        "--init",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "$SONARQUBE_TOKEN",
        "SONARQUBE_ORG": "$SONARQUBE_ORG",
        "SONARQUBE_URL": "https://sonarcloud.io",
        "SONARQUBE_IDE_PORT": "$SONARQUBE_IDE_PORT"
      }
    },
    "svelte": {
      "url": "https://mcp.svelte.dev/mcp",
      "type": "http"
    },
    "nanobanana": {
      "command": "node",
      "args": ["/home/node/nanobanana-mcp/mcp-server/dist/index.js"],
      "env": {
        "NANOBANANA_GEMINI_API_KEY": "$NANOBANANA_GEMINI_API_KEY"
      }
    }
  },
  "safeCommands": ["ls", "cat", "grep", "find"],
  "security": {
    "environmentVariableRedaction": {
      "allowed": [
        "NANOBANANA_GEMINI_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY"
      ]
    }
  }
}
