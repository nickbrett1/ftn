graph TD
    %% Nodes
    subgraph ClientDevices [Client Devices & Peripherals]
        iPadApp[iPad POS App<br/>Swift / iOS]
        BarcodeScanner[Tera Mini Barcode Scanner<br/>Bluetooth HID Mode]
        StripeReader[Stripe Reader M2<br/>Bluetooth BLE Mode]
        AveryPrinter[Avery Label Printer<br/>AirPrint / Browser Print]
    end

    subgraph ExternalServices [External Integrations]
        StripeAPI[Stripe API<br/>Terminal & Payments]
