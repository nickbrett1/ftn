        </div>
        <div class="grow space-y-2 text-center md:text-left">
            <div class="flex flex-col items-center md:items-start gap-1">
                <span class="px-2.5 py-0.5 text-xs font-mono font-bold tracking-wider uppercase bg-red-950/40 text-red-400 border border-red-800/50 rounded-md">Criminal #1</span>
                <h3 class="text-xl md:text-2xl font-bold text-white group-hover:text-red-400 transition-colors">The Smuggler</h3>
