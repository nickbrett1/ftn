	<div class="text-[10px] md:text-[11px] text-gray-400 uppercase tracking-widest font-semibold whitespace-nowrap">Agent Costs</div>
	<div class="text-sm md:text-3xl font-extrabold text-red-500">${currentCost}</div>
</div>

