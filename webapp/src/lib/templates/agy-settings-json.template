{
  "mcpServers": {
    "svelte": {
      "httpUrl": "https://mcp.svelte.dev/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ]
    }{{sonarQubeMcpConfig}}{{circleCiMcpConfig}}
  },
  "security": {
    "environmentVariableRedaction": {
      "allowed": [
        "NANOBANANA_GEMINI_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY"
      ]
    }
  }
}
